{
  "name": "@arrivd/email",
  "version": "0.1.2",
  "description": "Email deliverability audit — SPF, DKIM, DMARC, BIMI, MTA-STS checks in one command",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "arrivd": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "bun test"
  },
  "dependencies": {
    "@arrivd/core": "workspace:*"
  },
  "devDependencies": {
    "@arrivd/typescript-config": "workspace:*",
    "@types/node": "^22.15.0",
    "tsup": "^8.4.0"
  },
  "keywords": [
    "email",
    "deliverability",
    "spf",
    "dkim",
    "dmarc",
    "bimi",
    "mta-sts",
    "dns",
    "audit",
    "cli",
    "email-authentication",
    "spam"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/arrivd/arrivd.git",
    "directory": "packages/email"
  },
  "bugs": "https://github.com/arrivd/arrivd/issues"
}
