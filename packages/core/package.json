{
  "name": "@arrivd/core",
  "version": "0.1.1",
  "description": "Shared types, config, and reporting for arrivd deliverability modules",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "bun test"
  },
  "devDependencies": {
    "@arrivd/typescript-config": "workspace:*",
    "@types/node": "^22.15.0",
    "tsup": "^8.4.0"
  },
  "keywords": [
    "deliverability",
    "email",
    "webhooks",
    "cron",
    "monitoring",
    "spf",
    "dkim",
    "dmarc",
    "developer-tools"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/arrivd/arrivd.git",
    "directory": "packages/core"
  },
  "bugs": "https://github.com/arrivd/arrivd/issues"
}
