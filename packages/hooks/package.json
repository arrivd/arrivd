{
  "name": "@arrivd/hooks",
  "version": "0.1.1",
  "description": "Outgoing webhook delivery with retry, signing, and dead letter queue",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "bun test"
  },
  "dependencies": {
    "@arrivd/core": "workspace:*"
  },
  "devDependencies": {
    "@arrivd/typescript-config": "workspace:*",
    "@types/node": "^22.15.0",
    "tsup": "^8.4.0"
  },
  "keywords": [
    "webhooks",
    "retry",
    "signing",
    "hmac",
    "dead-letter-queue",
    "delivery",
    "outgoing"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/arrivd/arrivd.git",
    "directory": "packages/hooks"
  },
  "bugs": "https://github.com/arrivd/arrivd/issues"
}
